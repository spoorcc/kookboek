% kookboek.sty — Familie Spoor kookboek style
% Printed black-ink on sepia paper — all colours are greyscale.
% Engine: XeLaTeX or LuaLaTeX (needs fontspec). Build with: latexmk -xelatex main.tex
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{kookboek}[2026/06/28 Familie Spoor kookboek]

% ----------------------------------------------------------------------------
% Page geometry — classic cookbook trim 19 x 24 cm, generous outer margin for
% margin notes and ingredient sketches.
% ----------------------------------------------------------------------------
\RequirePackage[
  paperwidth=19cm, paperheight=24cm,
  top=2.4cm, bottom=2.6cm, inner=2.1cm, outer=3.6cm,
  marginparwidth=2.5cm, marginparsep=0.5cm, headsep=1.0cm
]{geometry}

% ----------------------------------------------------------------------------
% Colours — greyscale for black-ink print on sepia paper.
% No background set: the physical paper provides the warm tone.
% ----------------------------------------------------------------------------
\RequirePackage{xcolor}
\definecolor{paper}{HTML}{FFFFFF}   % used only for fcolorbox fills
\definecolor{ink}{HTML}{000000}
\definecolor{terracotta}{HTML}{555555}  % mid-grey accent (was terracotta)
\definecolor{olive}{HTML}{888888}
\definecolor{inkfaint}{HTML}{888888}

\color{ink}

% ----------------------------------------------------------------------------
% Fonts. Install these (Google Fonts), or drop the .ttf files in ./fonts and
% uncomment the [Path=...] options.
%   - EB Garamond            (body + serif headings)
%   - Nothing You Could Do   (handwriting accent — titles, Tip van Ben)
%   - optional: Juliana (Sem Hartz) for the family name on the cover
% ----------------------------------------------------------------------------
\RequirePackage{fontspec}
\setmainfont{EB Garamond}[
  Path = fonts/ , Extension = .ttf ,
  UprightFont = EBGaramond-Regular, ItalicFont = EBGaramond-Italic, BoldFont = EBGaramond-SemiBold,
  Ligatures = TeX, Numbers = OldStyle ]
\newfontfamily\handfont{Nothing You Could Do}[
  Path = fonts/ , Extension = .ttf ,
  UprightFont = NothingYouCouldDo-Regular,
  Ligatures = TeX]
% Family name on the cover. Swap "EB Garamond" for "Juliana" if you license it.
\newfontfamily\julianafont{EB Garamond}[
  Path = fonts/ , Extension = .ttf ,
  UprightFont = EBGaramond-Regular,
  Numbers = Lining]

\RequirePackage{amssymb}
\RequirePackage{microtype}

% ----------------------------------------------------------------------------
% Headings — chapters are CATEGORIES (Hoofdgerechten ...), sections are
% RECIPES, subsections are GROUPS of recipes within a chapter (Pasta \&
% risotto ...). Numbers are suppressed throughout (empty titlesec label +
% secnumdepth capped below subsections), so nothing but the Inhoud page
% numbers ever shows a digit.
% ----------------------------------------------------------------------------
\RequirePackage{titlesec}
\setcounter{secnumdepth}{1}
\titleformat{\chapter}[display]
  {\normalfont}
  {}
  {0pt}
  {\scshape\color{ink}\fontsize{20}{24}\selectfont\addfontfeatures{LetterSpace=10.0}}
  [\vspace{4pt}{\color{terracotta}\titlerule[0.5pt]}]
\titlespacing*{\chapter}{0pt}{0pt}{28pt}

% Recipe titles are set in a large handwriting font at a fixed size; long
% titles don't reliably break onto a second line on their own and can run
% past the text width. \fittitle measures the title and only switches to an
% explicitly wrapping \parbox when it would overflow, leaving short titles
% untouched.
\newsavebox{\recipetitlebox}
\newcommand{\fittitle}[1]{%
  \sbox{\recipetitlebox}{\handfont\fontsize{32}{34}\selectfont#1}%
  \ifdim\wd\recipetitlebox>\textwidth
    \parbox[t]{\textwidth}{\raggedright\handfont\fontsize{32}{34}\selectfont#1}%
  \else
    \usebox{\recipetitlebox}%
  \fi
}

\titleformat{\section}
  {\normalfont}
  {}
  {0pt}
  {\color{ink}}
\titlespacing*{\section}{0pt}{6pt}{2pt}

\titleformat{\subsection}[display]
  {\normalfont}
  {}
  {0pt}
  {\scshape\color{terracotta}\fontsize{15}{18}\selectfont\addfontfeatures{LetterSpace=14.0}}
\titlespacing*{\subsection}{0pt}{0pt}{28pt}

% A group divider within a chapter: starts a fresh page (like \chapter does)
% and adds an unnumbered entry to the Inhoud, indented under the chapter.
% Usage: \subchapter{Pasta \& risotto}
\newcommand{\subchapter}[1]{\clearpage\subsection{#1}}

% ----------------------------------------------------------------------------
% Running heads + folio.
% ----------------------------------------------------------------------------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[LE]{\itshape\small\color{inkfaint}Kookboek van onze familie}
\fancyhead[RO]{\scshape\small\color{terracotta}\nouppercase{\leftmark}}
\fancyfoot[C]{\color{terracotta}\rule[0.35ex]{1.4em}{0.4pt}\;\small\thepage\;\rule[0.35ex]{1.4em}{0.4pt}}
\fancypagestyle{plain}{%
  \fancyhf{}\renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\color{terracotta}\rule[0.35ex]{1.4em}{0.4pt}\;\small\thepage\;\rule[0.35ex]{1.4em}{0.4pt}}}

% ----------------------------------------------------------------------------
% Drop caps (terracotta).
% ----------------------------------------------------------------------------
\RequirePackage{lettrine}
\renewcommand{\LettrineFontHook}{\color{terracotta}}

% ----------------------------------------------------------------------------
% Lists, columns, graphics, index.
% ----------------------------------------------------------------------------
\RequirePackage{multicol}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\RequirePackage{enumitem}
\RequirePackage{imakeidx}
\RequirePackage[hidelinks]{hyperref}

\makeindex[name=register, title=Register, intoc=true]

% ---- Recipe building blocks -------------------------------------------------

% Small-caps category line above the recipe title, e.g. \kicker{Hoofdgerecht}
\newcommand{\kicker}[1]{{\footnotesize\scshape\color{terracotta}\addfontfeatures{LetterSpace=18.0}#1}\par\vspace{2pt}}

% Diamond separator for the meta line.
\newcommand{\dvd}{\,\textcolor{terracotta}{\raisebox{0.1ex}{$\scriptstyle\blacklozenge$}}\,}
% Meta line: \meta{40 minuten \dvd Voor 5 personen \dvd Italiaans}
\newcommand{\meta}[1]{{\footnotesize\scshape\color{terracotta}#1}\par\vspace{1.2em}}

% Labelled rule used before Ingrediënten / Bereiding.
\newcommand{\blockrule}[1]{\par\vspace{1.0em}%
  \noindent{\scshape\color{ink}\addfontfeatures{LetterSpace=16.0}#1}\par
  \vspace{-0.2em}{\color{terracotta}\rule{\textwidth}{0.4pt}}\par\vspace{0.7em}}

% Hero illustration placeholder (compiles with no image). Replace with
% \heroimage{file}{caption} when you have the drawing.
\newcommand{\heroplaceholder}[1]{\par\noindent
  \begin{tikzpicture}
    \node[draw=terracotta, line width=0.4pt, rounded corners=1pt,
          minimum width=\textwidth, minimum height=4.8cm, inner sep=0,
          align=center, text=terracotta, font=\itshape] {hero-tekening van het gerecht};
  \end{tikzpicture}\\[3pt]
  {\footnotesize\itshape\color{terracotta}#1}\par\vspace{1.0em}}
\newcommand{\heroimage}[2]{\par\noindent
  \fcolorbox{terracotta}{paper}{\includegraphics[width=\dimexpr\textwidth-2\fboxsep-2\fboxrule\relax, height=4.8cm, keepaspectratio]{#1}}\\[3pt]
  {\footnotesize\itshape\color{terracotta}#2}\par\vspace{1.0em}}

% A loose, hand-labelled ingredient sketch in the margin.
\newcommand{\ingredientsketch}[1]{\marginpar{\centering
  \begin{tikzpicture}
    \node[draw=terracotta, dashed, line width=0.3pt, minimum width=\marginparwidth,
          minimum height=2.5cm, inner sep=0, text=terracotta, font=\handfont] {#1};
  \end{tikzpicture}}}

% Margin tip: \tip{...}
\newcommand{\tip}[1]{\marginpar{\raggedright
  {\color{terracotta}\rule{\marginparwidth}{1pt}}\\[5pt]
  {\handfont\Large\color{terracotta}Tip van Ben}\\[3pt]
  {\footnotesize\itshape #1}}}

% Ingredients: two columns of "amount  name".
\newenvironment{ingredients}
  {\par\begin{multicols}{2}\setlength{\parindent}{0pt}\small}
  {\end{multicols}\vspace{0.4em}}
\newcommand{\ing}[2]{\hangindent=\dimexpr1.7cm+0.5em\relax\hangafter=1
  \makebox[1.7cm][r]{\color{terracotta}#1}\hspace{0.5em}#2\par\vspace{0.35em}}
% Bulleted ingredient (when amounts are "op gevoel").
\newcommand{\ingb}[1]{\hangindent=\dimexpr1.7cm+0.5em\relax\hangafter=1
  \makebox[1.7cm][r]{\textcolor{terracotta}{\raisebox{0.15ex}{$\scriptstyle\blacklozenge$}}}\hspace{0.5em}#1\par\vspace{0.35em}}

% Numbered preparation steps with terracotta numerals.
\newlist{steps}{enumerate}{1}
\setlist[steps]{label=\textcolor{terracotta}{\large\arabic*}, leftmargin=2.3em,
                labelsep=0.7em, itemsep=0.55em, topsep=0.2em}

% Fillable ruled lines (for recipes whose method you haven't written down yet).
\newcommand{\writelines}[1]{\par\vspace{0.4em}%
  \foreach \i in {1,...,#1}{\noindent\textcolor{ink!40}{\dotfill}\par\vspace{0.9em}}}

% Recipe environment: starts each recipe on a fresh page. The title is
% passed as \section's optional (short-title) argument too, so the Inhoud,
% running head, and PDF bookmark get the plain text even when \fittitle
% wraps the on-page title in a \parbox.
\newenvironment{recipe}[1]{\clearpage\section[#1]{\fittitle{#1}}}{}

\endinput
