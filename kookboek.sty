% kookboek.sty — Familie Spoor kookboek style
% Printed black-ink on sepia paper — all colours are greyscale.
% Engine: XeLaTeX or LuaLaTeX (needs fontspec). Build with: latexmk -xelatex main.tex
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{kookboek}[2026/06/28 Familie Spoor kookboek]

% ----------------------------------------------------------------------------
% Page geometry — Lulu Crown Quarto text-block trim (189 x 246 mm /
% 7.44 x 9.68 in), generous outer margin for margin notes and ingredient
% sketches. This is the trim of the printed page block itself, which for
% a hardcover casewrap book is smaller than the cover's case/board size
% (see cover/cover.tex) — the case wraps around the block with a small
% overhang on every outer edge, so the two files are sized independently.
% ----------------------------------------------------------------------------
% outer=4.9cm: the outer margin has to hold the marginparsep+marginparwidth
% (0.5cm+2.5cm=3cm) reserved for \tip/\ingredientsketch AND still leave
% Lulu's safety buffer beyond that reserved box, not just beyond the text
% column. 3.6cm only left 0.6cm of buffer past the marginpar itself (below
% Lulu's 12.7mm minimum) even though the declared "outer" value alone read
% as safe — Lulu's check (and lulu_lint.py's) only sees the declared
% top/bottom/inner/outer numbers, not what's drawn inside them. 4.9cm
% leaves ~1.9cm past the marginpar, matching Lulu's own suggested 0.75in
% outside margin.
\RequirePackage[
  paperwidth=189mm, paperheight=246mm,
  top=2.4cm, bottom=2.6cm, inner=2.1cm, outer=4.5cm,
  marginparwidth=2.5cm, marginparsep=0.5cm, headsep=1.0cm
]{geometry}

% ----------------------------------------------------------------------------
% Colours — greyscale for black-ink print on sepia paper.
% No background set: the physical paper provides the warm tone.
% ----------------------------------------------------------------------------
\RequirePackage{xcolor}
\definecolor{paper}{HTML}{FFFFFF}   % used only for fcolorbox fills
\definecolor{ink}{HTML}{000000}
\definecolor{terracotta}{HTML}{555555}  % mid-grey accent (was terracotta)
\definecolor{olive}{HTML}{888888}
\definecolor{inkfaint}{HTML}{888888}

\color{ink}

% ----------------------------------------------------------------------------
% Fonts. Install these (Google Fonts), or drop the .ttf files in ./fonts and
% uncomment the [Path=...] options.
%   - EB Garamond            (body + serif headings)
%   - Nothing You Could Do   (handwriting accent — titles, Tip van Ben)
%   - optional: Juliana (Sem Hartz) for the family name on the cover
% ----------------------------------------------------------------------------
\RequirePackage{fontspec}
% The vendored EBGaramond-*.ttf builds only expose frac/liga/locl/pnum/tnum
% in their GSUB table — no onum or lnum — so requesting Numbers=OldStyle or
% Numbers=Lining is a silent no-op that only produces a fontspec warning per
% occurrence (hundreds, across the whole book). Left unset here; swap in a
% build of EB Garamond with old-style figures if that look is wanted later.
\setmainfont{EB Garamond}[
  Path = fonts/ , Extension = .ttf ,
  UprightFont = EBGaramond-Regular, ItalicFont = EBGaramond-Italic, BoldFont = EBGaramond-SemiBold,
  Ligatures = TeX ]
\newfontfamily\handfont{Nothing You Could Do}[
  Path = fonts/ , Extension = .ttf ,
  UprightFont = NothingYouCouldDo-Regular,
  Ligatures = TeX]
% Family name on the cover. Swap "EB Garamond" for "Juliana" if you license it.
\newfontfamily\julianafont{EB Garamond}[
  Path = fonts/ , Extension = .ttf ,
  UprightFont = EBGaramond-Regular]

% The vendored EB Garamond .ttf exposes no smcp/c2sc GSUB feature (see the
% Numbers=OldStyle/Lining comment above for the same root cause), so
% \scshape silently falls back to plain upright text instead of small caps.
% \labelcaps fakes the label look with tracked full capitals instead. Kept
% in sync with the same definition in cover/cover.tex (a standalone
% document that can't \usepackage this file).
\newcommand{\labelcaps}[2]{\addfontfeatures{LetterSpace=#1}\MakeUppercase{#2}}

% Dutch hyphenation. Without this, TeX has no pattern set for Dutch and
% can't break long compound words — deadly in the narrow \tip marginpar
% column (marginparwidth=2.5cm), where an unhyphenated word simply
% doesn't fit and overflows past the page's outer edge.
\RequirePackage{polyglossia}
\setmainlanguage{dutch}

\RequirePackage{amssymb}
% microtype's shipped mt-EBGaramond.cfg protrusion profile references
% historical ligature/oldstyle-figure glyph slots (e.g. /f.long, /nine.tosf)
% that the vendored EBGaramond-*.ttf builds don't contain, producing a
% "Unknown slot number" warning for every such glyph microtype tries to look
% up (hundreds, across the whole book). Harmless — microtype just skips
% protrusion for those glyphs — so the warning is filtered rather than
% disabling protrusion outright.
\RequirePackage{silence}
\WarningFilter{microtype}{Unknown slot number of character}
\RequirePackage{microtype}

% LaTeX's native \marginpar just drops its box at the vertical position
% where it's called and never checks whether it still fits above the
% bottom margin. A \tip{} anchored low on a page (e.g. after a long
% ingredient list) can run its text straight past the bottom edge.
% marginfix repositions margin notes so they stay within the text height.
\RequirePackage{marginfix}

% ----------------------------------------------------------------------------
% Headings — chapters are CATEGORIES (Hoofdgerechten ...), sections are
% RECIPES, subsections are GROUPS of recipes within a chapter (Pasta \&
% risotto ...). Numbers are suppressed throughout (empty titlesec label +
% secnumdepth capped below subsections), so nothing but the Inhoud page
% numbers ever shows a digit.
% ----------------------------------------------------------------------------
\RequirePackage{titlesec}
\setcounter{secnumdepth}{1}
\titleformat{\chapter}[display]
  {\normalfont}
  {}
  {0pt}
  {\scshape\color{ink}\fontsize{20}{24}\selectfont\addfontfeatures{LetterSpace=10.0}}
  [\vspace{4pt}{\color{terracotta}\titlerule[0.5pt]}]
\titlespacing*{\chapter}{0pt}{0pt}{28pt}

% Recipe titles are set in a large handwriting font at a fixed size; long
% titles don't reliably break onto a second line on their own and can run
% past the text width. \fittitle measures the title and only switches to an
% explicitly wrapping \parbox when it would overflow, leaving short titles
% untouched.
\newsavebox{\recipetitlebox}
\newcommand{\fittitle}[1]{%
  \sbox{\recipetitlebox}{\handfont\fontsize{32}{34}\selectfont#1}%
  \ifdim\wd\recipetitlebox>\textwidth
    \parbox[t]{\textwidth}{\raggedright\handfont\fontsize{32}{34}\selectfont#1}%
  \else
    \usebox{\recipetitlebox}%
  \fi
}

\titleformat{\section}
  {\normalfont}
  {}
  {0pt}
  {\color{ink}}
\titlespacing*{\section}{0pt}{6pt}{2pt}

\titleformat{\subsection}[display]
  {\normalfont}
  {}
  {0pt}
  {\scshape\color{terracotta}\fontsize{15}{18}\selectfont\addfontfeatures{LetterSpace=14.0}}
\titlespacing*{\subsection}{0pt}{0pt}{28pt}

% A group divider within a chapter: starts a fresh page (like \chapter does)
% and adds an unnumbered entry to the Inhoud, indented under the chapter.
% Usage: \subchapter{Pasta \& risotto}
\newcommand{\subchapter}[1]{\clearpage\subsection{#1}}

% Left to the book class default, a \subchapter's Inhoud entry is set in
% the same plain roman as every recipe title around it, so group dividers
% like "Pasta & risotto" disappear into the list instead of reading as a
% break. Give it the same small-caps terracotta treatment as the in-book
% subsection heading, plus some air above, so it reads as a sub-heading at
% a glance. Indent/numwidth (3.8em/3.2em) are untouched from the book class
% default to keep its title text aligned with the recipe titles above it.
\renewcommand*{\l@subsection}[2]{%
  \addvspace{10pt plus 2pt}%
  \@dottedtocline{2}{3.8em}{3.2em}%
    {\scshape\color{terracotta}\addfontfeatures{LetterSpace=8.0}#1}%
    {\color{terracotta}#2}}

% ----------------------------------------------------------------------------
% Running heads + folio.
% ----------------------------------------------------------------------------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[LE]{\itshape\small\color{inkfaint}Kookboek van onze familie}
\fancyhead[RO]{\scshape\small\color{terracotta}\nouppercase{\leftmark}}
\fancyfoot[C]{\color{terracotta}\rule[0.35ex]{1.4em}{0.4pt}\;\small\thepage\;\rule[0.35ex]{1.4em}{0.4pt}}
\fancypagestyle{plain}{%
  \fancyhf{}\renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\color{terracotta}\rule[0.35ex]{1.4em}{0.4pt}\;\small\thepage\;\rule[0.35ex]{1.4em}{0.4pt}}}

% ----------------------------------------------------------------------------
% Drop caps (terracotta).
% ----------------------------------------------------------------------------
\RequirePackage{lettrine}
\renewcommand{\LettrineFontHook}{\color{terracotta}}

% ----------------------------------------------------------------------------
% Lists, columns, graphics, index.
% ----------------------------------------------------------------------------
\RequirePackage{multicol}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{fadings}
% Fadings for cover art: each "vanishes" (fades to transparent) toward the
% named edge and stays opaque toward the opposite edge, so an overlay panel
% dissolves into the paper colour instead of cutting the artwork with a
% hard, guillotined edge. Kept in sync with the same definitions in
% cover/cover.tex.
\tikzfading[name=fade-vanish-top,    top color=transparent!100, bottom color=transparent!0]
\tikzfading[name=fade-vanish-bottom, top color=transparent!0,   bottom color=transparent!100]
\tikzfading[name=fade-vanish-left,   left color=transparent!100, right color=transparent!0]
\tikzfading[name=fade-vanish-right,  left color=transparent!0,   right color=transparent!100]
\RequirePackage{enumitem}
\RequirePackage{imakeidx}
\RequirePackage[hidelinks]{hyperref}

\makeindex[name=register, title=Register, intoc=true]

% ---- Recipe building blocks -------------------------------------------------

% Small-caps category line above the recipe title — properties of the dish
% itself (what ends up on the table), in order: course (Hoofdgerecht/
% Bijgerecht/Voorgerecht/Dessert/Bakken/Brood & basis), protein/diet (Vlees/
% Vis/Vegetarisch/Vegan/Zoet), cuisine (Italiaans, Mexicaans, ...), and an
% optional context tag (Doordeweeks, Kinderen, Kerst, Hartig, Pittig, ...).
% e.g. \kicker[Hoofdgerecht,Vlees,Italiaans]{Hoofdgerecht · vlees · Italiaans}
% Optional [Term1,Term2,...] arg registers those words in the Register, so a
% recipe's category/dietary/cuisine tags can be looked up like ingredients.
\newcommand{\kicker}[2][]{%
  \foreach \kickerterm in {#1} {\index[register]{\kickerterm}}%
  {\footnotesize\scshape\color{terracotta}\addfontfeatures{LetterSpace=18.0}#2}\par\vspace{2pt}}

% Diamond separator for the meta line.
\newcommand{\dvd}{\,\textcolor{terracotta}{\raisebox{0.1ex}{$\scriptstyle\blacklozenge$}}\,}
% Meta line — properties of the cooking itself, not the dish: bereidingstijd,
% dan optioneel portie-opbrengst, dan optioneel een bereidingswijze/moeite-tag
% (Eén pan, Snel, Eenvoudig, oventemperatuur, ...). Cuisine lives in \kicker,
% not here, so it isn't stated twice. e.g.:
% \meta{40 minuten \dvd Voor 6 porties \dvd Eén pan}
% Optional [Term,...] arg registers those words in the Register — for a
% meta-only word that isn't already covered by \kicker's terms.
\newcommand{\meta}[2][]{%
  \foreach \metaterm in {#1} {\index[register]{\metaterm}}%
  {\footnotesize\scshape\color{terracotta}#2}\par\vspace{1.2em}}

% Labelled rule used before Ingrediënten / Bereiding.
\newcommand{\blockrule}[1]{\par\vspace{1.0em}%
  \noindent{\scshape\color{ink}\addfontfeatures{LetterSpace=16.0}#1}\par
  \vspace{-0.2em}{\color{terracotta}\rule{\textwidth}{0.4pt}}\par\vspace{0.7em}}

% Hero illustration placeholder (compiles with no image). Replace with
% \heroimage{file}{caption} when you have the drawing.
\newcommand{\heroplaceholder}[1]{\par\noindent
  \begin{tikzpicture}
    \node[draw=terracotta, line width=0.4pt, rounded corners=1pt,
          minimum width=\textwidth, minimum height=4.8cm, inner sep=0,
          align=center, text=terracotta, font=\itshape] {hero-tekening van het gerecht};
  \end{tikzpicture}\\[3pt]
  {\footnotesize\itshape\color{terracotta}#1}\par\vspace{1.0em}}
\newcommand{\heroimage}[2]{\par\noindent
  \fcolorbox{terracotta}{paper}{\includegraphics[width=\dimexpr\textwidth-2\fboxsep-2\fboxrule\relax, height=4.8cm, keepaspectratio]{#1}}\\[3pt]
  {\footnotesize\itshape\color{terracotta}#2}\par\vspace{1.0em}}

% Full-width, borderless, uncaptioned photo (e.g. a closing shot after a
% recipe's steps). Spans the full margin-to-margin width — \textwidth plus
% the \tip column's marginparsep+marginparwidth — not just the text column,
% so it bleeds out to the same outer boundary the tip sidebar itself uses.
%
% Usage: \heroimagefade[<keys>]{file}, e.g.
%   \heroimagefade{images/roti}                     recto, default fade width
%   \heroimagefade[verso]{images/kalkoen-in-spek}    verso, default fade width
%   \heroimagefade[verso, fadewidth=2.5cm]{images/x} verso, wider fade
%   \heroimagefade[fadewidth=0.6cm]{images/y}        recto, thinner fade
%
% side (recto/verso, default: auto-detected): since the tip column sits on
% a different physical side on recto/verso pages (twoside geometry mirrors
% inner/outer), the extra width must go on the correct side. This is
% auto-detected via a \label/\getpagerefnumber round-trip: each
% \heroimagefade instance gets its own numbered label, written *after* the
% image (not before) so that if the image is wide enough to start a fresh
% page on its own, the page-break decision has already been made by the
% time the label is written — the label then always lands on the same
% page as the image itself. The side is read from that label's page
% number as resolved by the *previous* compile (hence \getpagerefnumber,
% not \ifodd\value{page}, which would read today's not-yet-finalised
% page), so this needs the usual rerun-for-cross-references pass —
% latexmk (what build.sh uses) already reruns automatically until labels
% stabilise, and switching side never changes the vertical space an image
% takes, so it can't itself cause the page numbers to keep moving.
% First pass, before any label exists yet, falls back to recto. Belt and
% braces: scripts/lulu_lint.py's full-bleed check samples actual pixel
% colour at the page edge on the built PDF and fails loudly if a wrong
% guess ever pushes real artwork to the trim, so a bad guess can't pass
% silently — it was exactly this check that caught the three recto/verso
% mismatches this auto-detection replaces. Force a side explicitly with
% [recto] / [verso] if the auto-detection ever needs overriding.
%
% fadewidth (default \heroimagefadewidth): how wide a band along each edge
% fades toward the paper colour, tweakable per image — a photo with a lot
% of its own white space at the edges can take a wider, softer fade, while
% one with content close to the edge needs a thinner one.
\def\heroimgfaderecto{recto}
\def\heroimgfadeauto{auto}
\newlength{\heroimagefadewidth}
\setlength{\heroimagefadewidth}{1.6cm}
\newcounter{heroimagefadenum}
\newcount\heroimgfadepagenum
\pgfkeys{
  /heroimagefade/side/.store in=\heroimgfadeside,
  /heroimagefade/side/.default=recto,
  /heroimagefade/recto/.style={/heroimagefade/side=recto},
  /heroimagefade/verso/.style={/heroimagefade/side=verso},
  /heroimagefade/fadewidth/.store in=\heroimgfadewidthval,
}
\newcommand{\heroimagefade}[2][]{%
  \stepcounter{heroimagefadenum}%
  \edef\heroimgfadelabel{heroimagefade@\theheroimagefadenum}%
  \def\heroimgfadeside{auto}%
  \edef\heroimgfadewidthval{\the\heroimagefadewidth}%
  \pgfkeys{/heroimagefade/.cd, #1}%
  \ifx\heroimgfadeside\heroimgfadeauto
    \heroimgfadepagenum=\getpagerefnumber{\heroimgfadelabel}\relax
    \ifnum\heroimgfadepagenum=0
      \def\heroimgfadeside{recto}% no data yet (first pass): safe default
    \else
      \ifodd\heroimgfadepagenum
        \def\heroimgfadeside{recto}%
      \else
        \def\heroimgfadeside{verso}%
      \fi
    \fi
  \fi
  \par\noindent
  \ifx\heroimgfadeside\heroimgfaderecto\else
    \hspace*{-\dimexpr\marginparsep+\marginparwidth\relax}%
  \fi
  \begin{tikzpicture}
    \node[inner sep=0, outer sep=0] (heroimgfade)
      {\includegraphics[width=\dimexpr\textwidth+\marginparsep+\marginparwidth\relax]{#2}};
    \fill[paper, path fading=fade-vanish-bottom]
      (heroimgfade.north west) rectangle ([yshift=-\heroimgfadewidthval]heroimgfade.north east);
    \fill[paper, path fading=fade-vanish-top]
      ([yshift=\heroimgfadewidthval]heroimgfade.south west) rectangle (heroimgfade.south east);
    \fill[paper, path fading=fade-vanish-right]
      (heroimgfade.south west) rectangle ([xshift=\heroimgfadewidthval]heroimgfade.north west);
    \fill[paper, path fading=fade-vanish-left]
      ([xshift=-\heroimgfadewidthval]heroimgfade.south east) rectangle (heroimgfade.north east);
  \end{tikzpicture}
  \label{\heroimgfadelabel}%
  \par\vspace{1.0em}}

% A loose, hand-labelled ingredient sketch in the margin.
\newcommand{\ingredientsketch}[1]{\marginpar{\centering
  \begin{tikzpicture}
    \node[draw=terracotta, dashed, line width=0.3pt, minimum width=\marginparwidth,
          minimum height=2.5cm, inner sep=0, text=terracotta, font=\handfont] {#1};
  \end{tikzpicture}}}

% Margin tip: \tip{...}
\newcommand{\tip}[1]{\marginpar{\raggedright
  {\color{terracotta}\rule{\marginparwidth}{1pt}}\\[5pt]
  {\handfont\Large\color{terracotta}Tip van Ben}\\[3pt]
  {\footnotesize\itshape #1}}}

% Ingredients: two columns of "amount  name".
\newenvironment{ingredients}
  {\par\begin{multicols}{2}\setlength{\parindent}{0pt}\small}
  {\end{multicols}\vspace{0.4em}}
\newcommand{\ing}[2]{\hangindent=\dimexpr1.7cm+0.5em\relax\hangafter=1
  \makebox[1.7cm][r]{\color{terracotta}#1}\hspace{0.5em}#2\par\vspace{0.35em}}
% Bulleted ingredient (when amounts are "op gevoel").
\newcommand{\ingb}[1]{\hangindent=\dimexpr1.7cm+0.5em\relax\hangafter=1
  \makebox[1.7cm][r]{\textcolor{terracotta}{\raisebox{0.15ex}{$\scriptstyle\blacklozenge$}}}\hspace{0.5em}#1\par\vspace{0.35em}}

% Numbered preparation steps with terracotta numerals.
\newlist{steps}{enumerate}{1}
\setlist[steps]{label=\textcolor{terracotta}{\large\arabic*}, leftmargin=2.3em,
                labelsep=0.7em, itemsep=0.55em, topsep=0.2em}

% Fillable ruled lines (for recipes whose method you haven't written down yet).
\newcommand{\writelines}[1]{\par\vspace{0.4em}%
  \foreach \i in {1,...,#1}{\noindent\textcolor{ink!40}{\dotfill}\par\vspace{0.9em}}}

% Recipe environment: starts each recipe on a fresh page. The title is
% passed as \section's optional (short-title) argument too, so the Inhoud,
% running head, and PDF bookmark get the plain text even when \fittitle
% wraps the on-page title in a \parbox.
\newenvironment{recipe}[1]{\clearpage\section[#1]{\fittitle{#1}}}{}

\endinput
